# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (root and any nested service, e.g. services/office-converter)
/node_modules
**/node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# scratch / temp
scratch/
temp/
tmp/

# editors and ide
.vscode/
.idea/
.claude/
.cursor/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
